{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "python3 scripts/build_sites.py",
  "outputDirectory": "dist/client",
  "functions": {
    "api/transcribe.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/recommend", "destination": "/index.html" },
    { "source": "/search", "destination": "/index.html" }
  ]
}
